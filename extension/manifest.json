{
  "manifest_version": 3,
  "name": "agee",
  "version": "0.1.0",
  "description": "Open-source browser agent. Cmd+K, bring your own key. It sees your page and acts in it.",
  "permissions": ["activeTab", "tabs", "scripting", "storage", "debugger"],
  "host_permissions": ["https://api.anthropic.com/*", "http://localhost/*", "http://10.147.17.10/*", "http://10.147.17.6/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["tweaks.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "commands": {
    "toggle-agee": {
      "suggested_key": {
        "mac": "Command+K",
        "default": "Ctrl+K"
      },
      "description": "Open agee command mode"
    }
  },
  "action": {
    "default_title": "agee — open settings"
  }
}
